PC_NAME=redmine-sv

MYSQL_ROOT_PASSWORD=root_pass

# DB_ROOT_PASSWORD=root_pass
DB_NAME_WP=it_media_db
DB_USER_WP=wp_user
DB_PASSWORD_WP=wp_pass

DB_NAME_REDMINE=redmine_db
DB_USER_REDMINE=redmine_user
DB_PASSWORD_REDMINE=redmine_pass

# === Postfix コンテナ経由でメール送信 ===
SMTP_ADDRESS=postfix               # Postfix コンテナ名 (docker-compose内部)
SMTP_PORT=587                      # Postfix の受付ポート
SMTP_DOMAIN=example.lg.jp          # TODO: 自組織のドメイン名に変更
SMTP_AUTH=none                     # 内部 Postfix には認証不要
SMTP_USER=                         # 認証不要なので空
SMTP_PASSWORD=                     # 認証不要なので空
SMTP_TLS=false                     # 内部通信なので TLS 不要
# =====================================================

# === リマインダーメール設定 ===
# cron/config.ini の days=0 を変更することで対象日数を調整
# days=0: 期限切れチケットのみ
# days=7: 7日以内に期限が来るチケットも含む
# スケジュール変更は cron/config.ini の schedule を編集 (cron書式)

